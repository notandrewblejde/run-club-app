{
  "expo": {
    "name": "Run Club",
    "slug": "run-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "runclub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.runclub",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Run Club needs access to your photo library so you can choose a profile picture.",
        "NSCameraUsageDescription": "Run Club uses the camera if you choose to take a new profile photo.",
        "LSApplicationQueriesSchemes": [
          "strava"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "app.runclub",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-image-picker",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_AFTER_FIRST_EAS_BUILD"
      }
    }
  }
}
