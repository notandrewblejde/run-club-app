{
  "expo": {
    "name": "Run Club",
    "slug": "run-club",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "runclub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.runclub",
      "buildNumber": "20",
      "entitlements": {
        "com.apple.developer.healthkit.background-delivery": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "strava"
        ],
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "app.runclub",
      "versionCode": 20,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Run Club needs access to your photo library to set your profile picture, add photos to club posts, and attach images to your activities.",
          "cameraPermission": "Run Club uses the camera when you choose to take a new profile photo."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health/app.plugin.js",
        {
          "healthSharePermission": "Run Club reads running workouts, routes, and heart rate during those workouts from Apple Health so they can appear in your feed and inform coaching.",
          "healthUpdatePermission": "Run Club does not write workout data to Apple Health."
        }
      ],
      "react-native-health-connect",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0a0a0a",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "856ca734-4ff9-4980-9f31-566451e77397"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "andrewblejde"
  }
}
