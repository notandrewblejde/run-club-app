    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "axios": "^1.7.7",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.0",
    "expo-blur": "~14.0.1",
